VERSION 0.8

FROM golang:1.26-alpine

WORKDIR /app

deps:
    COPY go.mod go.sum* ./
    COPY ../../+gen-mod/gen ../gen
    COPY ../../+pkg-auth-mod/pkg-auth ../pkg/auth
    COPY ../../+pkg-kafka-mod/pkg-kafka ../pkg/kafka
    ENV GOWORK=off
    RUN go mod download && (cd ../gen && go mod download) && (cd ../pkg/auth && go mod download) && (cd ../pkg/kafka && go mod download)
    SAVE ARTIFACT go.mod AS LOCAL go.mod
    SAVE ARTIFACT go.sum AS LOCAL go.sum

src:
    FROM +deps
    COPY --dir cmd internal ./
    COPY ../../+gen-src/gen ../gen
    COPY ../../+pkg-auth-src/pkg-auth ../pkg/auth
    COPY ../../+pkg-kafka-src/pkg-kafka ../pkg/kafka

lint:
    FROM +src
    COPY ../../+golangci-config/.golangci.yml ./
    RUN go build ./...
    RUN go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.64.8
    RUN golangci-lint run ./...

test:
    FROM +src
    RUN go test ./internal/service/... ./internal/handler/... ./internal/consumer/... ./internal/bootstrap/... -v -count=1

integration-test:
    FROM +src
    WITH DOCKER
        RUN go test -tags integration ./... -v -count=1
    END

build:
    FROM +src
    RUN CGO_ENABLED=0 go build -o /bin/search ./cmd/
    RUN CGO_ENABLED=0 go build -o /bin/search-reindex ./cmd/reindex/
    SAVE ARTIFACT /bin/search
    SAVE ARTIFACT /bin/search-reindex

docker:
    FROM alpine:3.19
    RUN apk add --no-cache ca-certificates && addgroup -S app && adduser -S app -G app
    COPY +build/search /usr/local/bin/search
    COPY +build/search-reindex /usr/local/bin/search-reindex
    USER app
    EXPOSE 50054
    ENTRYPOINT ["/usr/local/bin/search"]
    SAVE IMAGE library-system/search:latest
